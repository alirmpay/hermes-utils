# Postgres Database
LITELLM_MASTER_KEY="sk-masterkey"
LITELLM_SALT_KEY="sk-saltkey"
POSTGRES_HOST=postgres_main
POSTGRES_PORT=5432
POSTGRES_DATABASE=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=astrongpasswrod

DATABASE_URL=postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$POSTGRES_DATABASE

# Optional UI credentials (if you want the LiteLLM admin UI)
UI_USERNAME=admin
UI_PASSWORD=changeme

# Redis (already wired in config.yaml)
REDIS_HOST=redis
REDIS_PORT=6379


# Langfuse
# Extract it from Langfuse panel after first run
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=http://langfuse-web:3000
