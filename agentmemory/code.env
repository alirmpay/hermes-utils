# =============================================================================
# agentmemory configuration
# =============================================================================

# -----------------------------------------------------------------------------
# 1. LLM provider — pick ONE
# -----------------------------------------------------------------------------

OPENAI_MODEL=qwen2.5-coder-7b

# Cap LLM completion tokens for compression / summarise calls
MAX_TOKENS=1024

# Outbound LLM / embedding timeout — shared across every raw-fetch provider
# (Gemini, OpenRouter, MiniMax, OpenAI LLM, and OpenAI/Cohere/Voyage/OpenRouter
# embedding). The OpenAI LLM path also honours the OpenAI-scoped
# OPENAI_TIMEOUT_MS alias for back-compat with v0.9.17 (precedence).
AGENTMEMORY_LLM_TIMEOUT_MS=300000                # Default: 60 000 ms (60 s)

# -----------------------------------------------------------------------------
# 2. Embedding provider — auto-detected, override via EMBEDDING_PROVIDER
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 3. Auth & security
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 4. Search tuning
# -----------------------------------------------------------------------------

BM25_WEIGHT=0.55                               # Hybrid search weight for BM25 leg
VECTOR_WEIGHT=0.35                             # Hybrid search weight for vector leg
AGENTMEMORY_GRAPH_WEIGHT=0.1                   # Graph traversal bonus on smart-search ranking
TOKEN_BUDGET=2500                              # Max tokens injected via mem::context per session
MAX_OBS_PER_SESSION=600                        # Per-session observation cap before consolidation kicks in
SUMMARIZE_CHUNK_SIZE=350                       # When mem::summarize sees a session larger than this, it chunks observations and map-reduces (chunk-summarize → reduce-merge) to stay within the LLM's context window. Default 400 ≈ 50k tokens per chunk at ~110 tok/obs. Native sessions are capped by MAX_OBS_PER_SESSION; chunking primarily matters for bulk-imported jsonl sessions, which bypass that cap.
SUMMARIZE_CHUNK_CONCURRENCY=3                  # Parallel chunk LLM calls during chunked summarize. Default 6 fits ~100-chunk sessions under iii's 180s function-invocation timeout at typical ~8s/call. High-throughput providers (Novita, DeepInfra, DeepSeek) commonly allow 100+ concurrent — bump this for very large imported sessions.

# -----------------------------------------------------------------------------
# 5. Behaviour flags
# -----------------------------------------------------------------------------

CONSOLIDATION_DECAY_DAYS=30                    # Age (days) after which non-reinforced memories decay during consolidation

GRAPH_EXTRACTION_BATCH_SIZE=6                  # Memories per graph-extraction batch

# -----------------------------------------------------------------------------
# 6. CLI / runtime knobs
# -----------------------------------------------------------------------------

AGENTMEMORY_URL=http://127.0.0.1:3111          # REST base URL — honored by status, doctor, MCP shim
AGENTMEMORY_VIEWER_URL=http://127.0.0.1:3113   # Override the viewer URL printed by `agentmemory status`
AGENTMEMORY_EXPORT_ROOT=~/agentmemory-backup/code   # Default destination for `agentmemory export`

SNAPSHOT_DIR=/data/snapshots

# Team sharing — when set, memories are scoped to (TEAM_ID, USER_ID) tuples.
# TEAM_MODE=shared
# TEAM_ID=
# USER_ID=rohit

# -----------------------------------------------------------------------------
# 7. Ports
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 8. iii engine pin
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 9. Claude Code bridge (opt-in)
# -----------------------------------------------------------------------------

# CLAUDE_MEMORY_BRIDGE=true                      # Mirror compressed memories into Claude Code's CLAUDE.md
# CLAUDE_PROJECT_PATH=/path/to/your/project      # Required when CLAUDE_MEMORY_BRIDGE=true
# CLAUDE_MEMORY_LINE_BUDGET=200                  # Lines of memory CLAUDE.md should hold

# -----------------------------------------------------------------------------
# 10. Obsidian export (opt-in)
# -----------------------------------------------------------------------------

# OBSIDIAN_AUTO_EXPORT=true                      # Auto-export memories to an Obsidian vault on every consolidation
